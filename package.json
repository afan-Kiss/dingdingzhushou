{
  "name": "dingtalk-checkin-helper",
  "version": "1.0.1",
  "description": "钉钉打卡确认助手 - 通过微信确认后打开钉钉考勤页并截图录屏",
  "main": "src/main.js",
  "scripts": {
    "start:morning": "node src/main.js morning",
    "start:evening": "node src/main.js evening",
    "start:auto": "node src/main.js auto",
    "dry-run": "node src/main.js morning --dry-run",
    "test-now": "node src/main.js morning --test-now",
    "check": "node src/test/check.js",
    "open:latest-report": "node src/test/open-latest-report.js",
    "test:wechat-text": "node src/test/wechat-text.js",
    "test:wechat-image": "node src/test/wechat-image.js",
    "test:wechat-reply": "node src/test/wechat-reply.js",
    "test:wechat-callback": "node src/test/wechat-callback.js",
    "test:adb": "node src/test/adb.js",
    "test:screenshot": "node src/test/screenshot.js",
    "test:recording": "node src/test/recording.js",
    "test:uiautomator": "node src/test/uiautomator.js",
    "test:full-morning-now": "node src/main.js morning --test-now",
    "test:full-evening-now": "node src/main.js evening --test-now",
    "test:open-attendance-now": "node src/test/open-attendance-now.js",
    "test:navigate-attendance": "node src/test/navigate-attendance.js",
    "test:checkin-click": "node src/test/checkin-click.js",
    "test:scrcpy-checkin": "node src/test/scrcpy-checkin-quick.js",
    "test:detect-page": "node src/test/detect-page.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": ["dingtalk", "checkin", "wxbot", "wechat"],
  "license": "MIT"
}
